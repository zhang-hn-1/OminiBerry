# -----------------------------------------------------------------------------
# 🌐 服务器基础配置
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0

# 应用监听端口
APP_PORT=8000

# 请求超时时间（秒）
REQUEST_TIMEOUT=600

# 运行目录 & 知识库目录
RUN_DIR=runs
KB_DIR=knowledge_bases

# -----------------------------------------------------------------------------
# 🤖 多智能体系统配置 (Multi-Agent)
# -----------------------------------------------------------------------------
# 主 LLM 提供商选择: local_transformers | openai
# 默认使用本地 transformers，如需切换至 OpenAI 兼容 API 请改为 openai
MULTIAGENT_LLM=local_transformers

# 【OpenAI 兼容配置】仅当 MULTIAGENT_LLM=openai 时生效
# 与基线 API 配置完全独立，支持任意 OpenAI 兼容端点
MULTIAGENT_OPENAI_BASE_URL=https://api.openai.com/v1
MULTIAGENT_OPENAI_API_KEY=your-openai-api-key
MULTIAGENT_OPENAI_MODEL=
# 是否信任环境变量中的 API KEY（生产环境建议设为 False）
MULTIAGENT_OPENAI_TRUST_ENV=False

# 多轮对话配置
N_ROUNDS=3

# 输出控制：严格匹配真实输出格式
STRICT_REAL_OUTPUT=true

# -----------------------------------------------------------------------------
# 📊 基线模型配置 (Baseline Single LLM)
# -----------------------------------------------------------------------------
BASELINE_OPENAI_BASE_URL=https://api.openai.com/v1
BASELINE_OPENAI_API_KEY=your-openai-api-key
BASELINE_OPENAI_MODEL=


# -----------------------------------------------------------------------------
# 🧠 本地大模型配置
# -----------------------------------------------------------------------------
# 本地模型权重路径
LOCAL_LLM_MODEL_DIR=/path/to/your/local-llm-model

# 最大生成长度（tokens）
LOCAL_LLM_MAX_NEW_TOKENS=8192

# 是否信任远程代码执行
LOCAL_LLM_TRUST_REMOTE_CODE=true

# 是否启用 Thinking 模式（如模型支持）
LOCAL_LLM_ENABLE_THINKING=false

# -----------------------------------------------------------------------------
# 🍅 番茄问答专家配置 (LoRA 微调模型)
# -----------------------------------------------------------------------------
# 基础模型路径（必须与 LOCAL_LLM_MODEL_DIR 一致或兼容）
BERRY_QA_EXPERT_MODEL_DIR=/path/to/your/base-model

# LoRA 适配器路径
BERRY_QA_EXPERT_ADAPTER_MODEL_DIR=/path/to/your/lora/checkpoint-xxx

# -----------------------------------------------------------------------------
# 👁️ 视觉模型配置 (Qwen3-VL)
# -----------------------------------------------------------------------------
# 是否启用本地 Qwen3-VL 模型
ENABLE_LOCAL_QWEN3_VL=true

# 视觉模型权重路径（必须是 VL 模型，非纯文本模型）
QWEN3_VL_MODEL_DIR=/path/to/your/qwen3-vl-model

# 视觉模型最大生成长度
QWEN3_VL_MAX_NEW_TOKENS=512

# -----------------------------------------------------------------------------
# 🔍 DINOv3 视觉编码器配置
# -----------------------------------------------------------------------------
# 是否启用本地 DINOv3 模型
ENABLE_LOCAL_DINOV3=true

# DINOv3 代码仓库路径
DINOV3_REPO_DIR=/path/to/your/dinov3-repo

# 模型权重路径
DINOV3_BACKBONE_WEIGHTS=/path/to/dinov3_vitl16_pretrain_*.pth
DINOV3_CLASSIFIER_HEAD_WEIGHTS=/path/to/best_classifier_head.pth
DINOV3_SEGMENTATION_HEAD_WEIGHTS=/path/to/best_segmentation_head.pth
# 模型下载前往google drive:https://drive.google.com/file/d/1Ho8hwJfxcNgE48hqz8k2TQP-6-JFYXzk/view?usp=drive_link

# 数据集配置
DINOV3_CLASSES_FILE=/path/to/classes.txt
DINOV3_IMAGE_SIZE=256
DINOV3_SEGMENTATION_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# 🗂️ 其他可选配置
# -----------------------------------------------------------------------------
# 模型路由配置文件路径（JSON 格式）
# 留空则使用默认路由逻辑；基线路由固定由 BASELINE_OPENAI_* 控制，不受此影响
AGENT_MODEL_ROUTING_JSON=

# 图像描述 Mock 数据路径（用于测试/调试）
CAPTION_MOCK_JSON_PATH=